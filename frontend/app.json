{
  "expo": {
    "name": "Passaroo",
    "slug": "passaroo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "passaroo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.passaroo.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Get daily study reminders to keep your streak alive",
        "NSUserTrackingUsageDescription": "Allow Passaroo to show personalised ads and measure performance",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.passaroo.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications",
      "./plugins/withSuprSendFcm",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9480363771925708~6873878189",
          "iosAppId": "ca-app-pub-9480363771925708~4247714848",
          "userTrackingUsageDescription": "Allow Passaroo to deliver relevant exam-prep offers and measure ad performance."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-tracking-transparency",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
